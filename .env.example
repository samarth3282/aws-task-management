# Copy this file to .env.local and fill in the values from your own backend
# (see BUILD.md and UPGRADE-GUIDE.md for exactly where each one comes from).

# BUILD.md, Phase 2, section 4.2 — Cognito User Pool
VITE_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_USER_POOL_CLIENT_ID=your_app_client_id

# BUILD.md, Phase 6, section 8.4 — API Gateway "Invoke URL" for the prod stage
# (no trailing slash)
VITE_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod
